      "id": 0,
      "name": "于桂英",
      "color": "#8279f2",
      "content": "因心怀珍宝，生活应该日渐月染。",
      "time": "刚刚",
      "imgs": [
        "assets/images/discover/friends/img10.jpg"
      ],
      "fromuserismember":0,
      "fromuserisvertify":0,
      "fromhead" : "assets/images/discover/friends/head_icon02",
      "commentid": 0,
      "weiboid" : 0,
